# SOLMON Mainnet Environment Variables
# Copy to .env.mainnet and fill in actual values

# Solana RPC (use dedicated RPC for mainnet, not public)
RPC_URL=https://api.mainnet-beta.solana.com

# Deployer keypair path
KEYPAIR_PATH=~/.config/solana/id.json

# Program IDs (filled after deploy)
CREATURE_PROGRAM_ID=
BATTLE_PROGRAM_ID=
TOKEN_PROGRAM_ID=
MARKETPLACE_PROGRAM_ID=

# IDL paths (after anchor build)
TOKEN_IDL=target/idl/solmon_token.json
CREATURE_IDL=target/idl/solmon_creature.json
BATTLE_IDL=target/idl/solmon_battle.json
MARKETPLACE_IDL=target/idl/solmon_marketplace.json

# Token mints (filled after init)
SOLMON_MINT=
SOLTREAT_MINT=

# Treasury wallet
TREASURY_WALLET=

# Marketplace fee recipient
FEE_RECIPIENT=

# Arweave (for metadata uploads)
ARWEAVE_KEY=
ARWEAVE_GATEWAY=https://arweave.net

# Frontend
NEXT_PUBLIC_SOLMON_MINT=
NEXT_PUBLIC_SOLTREAT_MINT=
NEXT_PUBLIC_CREATURE_PROGRAM=
NEXT_PUBLIC_BATTLE_PROGRAM=
NEXT_PUBLIC_TOKEN_PROGRAM=
NEXT_PUBLIC_MARKETPLACE_PROGRAM=
NEXT_PUBLIC_RPC_URL=https://api.mainnet-beta.solana.com
